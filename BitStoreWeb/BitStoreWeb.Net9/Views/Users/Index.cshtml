@model BitStoreWeb.Net9.Models.UsersViewModel
@{
    ViewData["Title"] = "Users";
}

<div class="mb-3">
    <h1 class="section-title mb-1">Users</h1>
    <p class="section-subtitle mb-0">SuperUser view of all registered accounts.</p>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="card mb-3 fade-in-up">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Registered Accounts</h2>
            <span class="badge text-bg-secondary">@Model.TotalUsers total</span>
        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th style="width: 10%;">Id</th>
                        <th style="width: 35%;">Username</th>
                        <th style="width: 20%;">Role</th>
                        <th style="width: 20%;">Created</th>
                        <th style="width: 10%;">Buckets</th>
                        <th style="width: 5%;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-muted">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@user.UserName</td>
                                <td><code>@user.Role</code></td>
                                <td>@user.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@user.BucketCount</td>
                                <td class="text-end">
                                    @if (!string.Equals(user.Role, Roles.SuperUser, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form asp-action="Delete" asp-controller="Users" asp-route-id="@user.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm d-inline-flex align-items-center justify-content-center" title="Delete user" aria-label="Delete user" onclick="return confirm('Delete this user and all of their buckets?');">
                                                <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card fade-in-up">
    <div class="card-body">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
            <div>
                <h2 class="h5 mb-1">Data Portability</h2>
                <p class="text-muted mb-0">Export or import all users, buckets, records, password hashes, and API keys.</p>
            </div>
            <a class="btn btn-outline-primary align-self-start" asp-action="Export" asp-controller="Users">
                <i class="fa-solid fa-download me-1" aria-hidden="true"></i>
                Export JSON
            </a>
        </div>

        <form asp-action="Import" asp-controller="Users" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-lg-6">
                <label asp-for="ImportFile" class="form-label">Import JSON</label>
                <input asp-for="ImportFile" type="file" accept="application/json,.json" class="form-control" />
            </div>
            <div class="col-lg-4">
                <div class="form-check">
                    <input asp-for="ReplaceExistingData" class="form-check-input" />
                    <label asp-for="ReplaceExistingData" class="form-check-label">Replace existing data</label>
                </div>
            </div>
            <div class="col-lg-2 text-lg-end">
                <button type="submit" class="btn btn-primary" onclick="return confirm('Import this file and replace existing data if selected?');">
                    <i class="fa-solid fa-upload me-1" aria-hidden="true"></i>
                    Import
                </button>
            </div>
        </form>
    </div>
</div>
